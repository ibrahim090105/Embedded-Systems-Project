class Motor {
public:
    Motor(PinName bipolarPin, PinName dirPin, PinName pwmPin,
          int forwardLevel, bool pwmInverted, bool bipolarFixedLow)
        : bipolar_(bipolarPin), dir_(dirPin), pwm_(pwmPin),
          forwardLevel_(forwardLevel), pwmInverted_(pwmInverted), bipolarFixedLow_(bipolarFixedLow) {
        pwm_.period_us(200); // PWM 频率约 5 kHz
        if (bipolarFixedLow_) {
            bipolar_ = 0;
        } else {
            bipolar_ = 0;
        }
        stop();
    }

    void stop() {
        apply(0.0f);
    }

    // 对上层提供带符号的百分比速度指令，范围 [-100, 100]
    void setSigned(float signedPercent) {
        if (signedPercent > 100.0f) signedPercent = 100.0f;
        if (signedPercent < -100.0f) signedPercent = -100.0f;

        if (signedPercent >= 0.0f) {
            dir_ = forwardLevel_ ? 1 : 0;
            apply(signedPercent);
        } else {
            dir_ = forwardLevel_ ? 0 : 1;
            apply(-signedPercent);
        }
    }

private:
    void apply(float magnitudePercent) {
        if (magnitudePercent < 0.0f) magnitudePercent = 0.0f;
        if (magnitudePercent > 100.0f) magnitudePercent = 100.0f;
        float duty = magnitudePercent / 100.0f;
        if (pwmInverted_) {
            duty = 1.0f - duty;
        }
        pwm_.write(duty);
    }

    DigitalOut bipolar_;
    DigitalOut dir_;
    PwmOut     pwm_;
    int        forwardLevel_;
    bool       pwmInverted_;
    bool       bipolarFixedLow_;
};

