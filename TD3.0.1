void debug_printf(const char* fmt, ...) {
    char buffer[220];
    va_list args;
    va_start(args, fmt);
    vsnprintf(buffer, sizeof(buffer), fmt, args);
    va_end(args);

    if (ENABLE_USB_DEBUG_OUTPUT) {
        pc.printf("%s", buffer);
    }
    if (ENABLE_BLE_DEBUG_OUTPUT) {
        hm10.printf("%s", buffer);
    }
}

const char* mode_name(RunMode mode) {
    switch (mode) {
        case MODE_IDLE:          return "IDLE";
        case MODE_SENSOR_DEBUG:  return "SENSOR_DBG";
        case MODE_MOTOR_DEBUG:   return "MOTOR_DBG";
        case MODE_ENCODER_DEBUG: return "ENC_DBG";
        case MODE_BLE_DEBUG:     return "BLE_DBG";
        case MODE_TD3_RUN:       return "TD3_RUN";
        default:                 return "UNKNOWN_MODE";
    }
}

