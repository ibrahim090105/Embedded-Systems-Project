// 调度器 ISR 

void scheduler_isr() {
    sysMs++;

    if ((sysMs % CONTROL_TASK_PERIOD_MS) == 0) {
        dueCtrl++;
    }
    if ((sysMs % SENSOR_TASK_PERIOD_MS) == 0) {
        due5ms++;
    }
    if ((sysMs % STATE_TASK_PERIOD_MS) == 0) {
        due20ms++;
    }
    if ((sysMs % CPU_REPORT_PERIOD_MS) == 0) {
        due5s++;
    }
}

static inline uint32_t fetch_due(volatile uint32_t& due) {
    __disable_irq();
    uint32_t n = due;
    due = 0;
    __enable_irq();
    return n;
}

//线传感器读取与位置估计 

void remap_line_arrays_to_logical_order() {
    for (int logical = 0; logical < 6; ++logical) {
        const int phys = LINE_LOGICAL_TO_PHYSICAL[logical];
        lineAmbient[logical] = lineAmbientPhys[phys];
        lineLit[logical]     = lineLitPhys[phys];
        lineSignal[logical]  = lineSignalPhys[phys];
    }
}

void adapt_line_estimates() {
    if (!LINE_AUTO_ADAPT) return;

    const bool definitelyBackground =
        (lineStrength <= LINE_ADAPT_BLACK_SUM_MAX) &&
        (lineMaxNorm  <= LINE_ADAPT_BLACK_MAX_MAX);

    const bool strongSingleWhite = (lineMaxNorm >= LINE_ADAPT_WHITE_MAX_MIN) && (lineMaxIndex >= 0);
    const bool strongPairWhite   = (linePairMaxNorm >= LINE_ADAPT_WHITE_PAIR_MIN) && (linePairIndex >= 0);

    // 只有明确处于背景时，才缓慢更新 black；这样可避免白线压在两路中间时污染黑参考。
    if (definitelyBackground) {
        for (int i = 0; i < 6; ++i) {
            LINE_BLACK_EST[i] += LINE_ADAPT_RATE_MIN * (lineSignal[i] - LINE_BLACK_EST[i]);
        }
    }

    // white 只做“门控式上调”，避免中间态或弱响应把 white 往下拉。
    if (strongSingleWhite) {
        const int i = lineMaxIndex;
        if (lineSignal[i] > LINE_WHITE_EST[i]) {
            LINE_WHITE_EST[i] += LINE_ADAPT_RATE_MAX * (lineSignal[i] - LINE_WHITE_EST[i]);
        }
    }
    if (strongPairWhite) {
        for (int k = 0; k < 2; ++k) {
            const int i = linePairIndex + k;
            if (i >= 0 && i < 6 && lineSignal[i] > LINE_WHITE_EST[i]) {
                LINE_WHITE_EST[i] += LINE_ADAPT_RATE_MAX * (lineSignal[i] - LINE_WHITE_EST[i]);
            }
        }
    }

    for (int i = 0; i < 6; ++i) {
        if (LINE_WHITE_EST[i] < LINE_BLACK_EST[i] + LINE_WHITE_FLOOR_MARGIN) {
            LINE_WHITE_EST[i] = LINE_BLACK_EST[i] + LINE_WHITE_FLOOR_MARGIN;
        }
    }
}

void read_line_sensors_compensated() {
    // 1) 关闭 LED，多次采样环境光并平均。
    set_all_line_leds(false);
    wait_us(LINE_LED_OFF_SETTLE_US);
    for (int i = 0; i < 6; ++i) {
        lineAmbientPhys[i] = 0.0f;
    }
    for (int sample = 0; sample < LINE_ADC_AVG_SAMPLES; ++sample) {
        for (int i = 0; i < 6; ++i) {
            lineAmbientPhys[i] += lineAdcPhys[i]->read();
        }
    }
    for (int i = 0; i < 6; ++i) {
        lineAmbientPhys[i] /= (float)LINE_ADC_AVG_SAMPLES;
    }

    // 2) 打开 LED，多次采样总光强（环境光 + 反射光）并平均。
    set_all_line_leds(true);
    wait_us(LINE_LED_ON_SETTLE_US);
    for (int i = 0; i < 6; ++i) {
        lineLitPhys[i] = 0.0f;
    }
    for (int sample = 0; sample < LINE_ADC_AVG_SAMPLES; ++sample) {
        for (int i = 0; i < 6; ++i) {
            lineLitPhys[i] += lineAdcPhys[i]->read();
        }
    }
    for (int i = 0; i < 6; ++i) {
        lineLitPhys[i] /= (float)LINE_ADC_AVG_SAMPLES;
        lineSignalPhys[i] = lineLitPhys[i] - lineAmbientPhys[i];
        if (lineSignalPhys[i] < 0.0f) lineSignalPhys[i] = 0.0f;
    }

    remap_line_arrays_to_logical_order();

    // 先用当前 black/white 参考进行归一化、估计位置与可见性。
    lineStrength    = 0.0f;
    lineMaxNorm     = 0.0f;
    linePairMaxNorm = 0.0f;
    lineMaxIndex    = -1;
    linePairIndex   = -1;
    float weightedSum = 0.0f;

    for (int i = 0; i < 6; ++i) {
        const float denom = (LINE_WHITE_EST[i] - LINE_BLACK_EST[i]);
        float n = 0.0f;
        if (denom > 0.0005f) {
            n = (lineSignal[i] - LINE_BLACK_EST[i]) / denom;
        }
        n = clampf(n, 0.0f, 1.0f);
        lineNorm[i] = n;
        lineStrength += n;
        weightedSum += n * LINE_POSITION_WEIGHTS[i];

        if (n > lineMaxNorm) {
            lineMaxNorm = n;
            lineMaxIndex = i;
        }
    }

    for (int i = 0; i < 5; ++i) {
        const float pairSum = lineNorm[i] + lineNorm[i + 1];
        if (pairSum > linePairMaxNorm) {
            linePairMaxNorm = pairSum;
            linePairIndex = i;
        }
    }

    // 可见判定升级：
    // 1) 单路明显强 -> 有线
    // 2) 两路相邻都中等，但和足够大 -> 也算有线（白线压在两传感器中间）
    // 3) 六路总和很强 -> 有线
    lineVisible = (lineMaxNorm >= LINE_VISIBLE_MAX_THRESHOLD) ||
                  (linePairMaxNorm >= LINE_VISIBLE_PAIR_THRESHOLD) ||
                  (lineStrength >= LINE_VISIBLE_SUM_THRESHOLD);

    // 基于当前观测门控更新 black/white 参考。
    adapt_line_estimates();

    if (lineVisible && lineStrength > 0.0001f) {
        linePosition = weightedSum / lineStrength;
        lineError = linePosition;
        lastLineSeenMs = sysMs;
        lineLostMs = 0;
    } else {
        lineLostMs += SENSOR_TASK_PERIOD_MS;
        // 保留上一次 lineError，供丢线恢复和搜索方向使用。
    }
}

//编码器、速度估计与 PI 控制 

void update_speed_estimates_and_PI() {
    // 每 CONTROL_TASK_PERIOD_MS 执行一次的带符号编码器增量
    const int32_t pulsesL = leftEncoder.getPulses();
    const int32_t pulsesR = rightEncoder.getPulses();

    int32_t deltaL = pulsesL - prevPulsesL;
    int32_t deltaR = pulsesR - prevPulsesR;
    prevPulsesL = pulsesL;
    prevPulsesR = pulsesR;

    deltaL *= ENCODER_L_SIGN;
    deltaR *= ENCODER_R_SIGN;

    const float controlHz = 1000.0f / (float)CONTROL_TASK_PERIOD_MS;
    const float instPctL = (deltaL * controlHz / MAX_WHEEL_PPS) * 100.0f;
    const float instPctR = (deltaR * controlHz / MAX_WHEEL_PPS) * 100.0f;

    actualSpeedLPct += SPEED_FILTER_ALPHA * (instPctL - actualSpeedLPct);
    actualSpeedRPct += SPEED_FILTER_ALPHA * (instPctR - actualSpeedRPct);

    // 仅在非空闲/非停止状态下运行 PI 速度环
    if (currentState == STATE_IDLE || currentState == STATE_STOPPED_WAIT_BLE || currentState == STATE_FAULT) {
        motorCmdLPct = 0.0f;
        motorCmdRPct = 0.0f;
        speedIntL = 0.0f;
        speedIntR = 0.0f;
    } else {
        const float dt = CONTROL_TASK_PERIOD_MS / 1000.0f;

        const float errL = targetSpeedLPct - actualSpeedLPct;
        const float errR = targetSpeedRPct - actualSpeedRPct;

        speedIntL += errL * dt * SPEED_KI;
        speedIntR += errR * dt * SPEED_KI;
        speedIntL = clampf(speedIntL, -SPEED_INTEGRAL_CLAMP, SPEED_INTEGRAL_CLAMP);
        speedIntR = clampf(speedIntR, -SPEED_INTEGRAL_CLAMP, SPEED_INTEGRAL_CLAMP);

        motorCmdLPct = targetSpeedLPct + SPEED_KP * errL + speedIntL;
        motorCmdRPct = targetSpeedRPct + SPEED_KP * errR + speedIntR;

        motorCmdLPct = clampf(motorCmdLPct, -100.0f, 100.0f);
        motorCmdRPct = clampf(motorCmdRPct, -100.0f, 100.0f);
    }

    // 将 PI 输出真正下发到电机
    leftMotor.setSigned(motorCmdLPct);
    rightMotor.setSigned(motorCmdRPct);
}

//BLE 命令与模式处理 

void set_mode(RunMode mode) {
    currentMode = mode;
    switch (mode) {
        case MODE_IDLE:
            currentState = STATE_IDLE;
            stop_all_motors();
            break;
        case MODE_SENSOR_DEBUG:
        case MODE_ENCODER_DEBUG:
        case MODE_BLE_DEBUG:
        case MODE_MOTOR_DEBUG:
            currentState = STATE_IDLE;
            stop_all_motors();
            break;
        case MODE_TD3_RUN:
            currentState = STATE_IDLE;
            stop_all_motors();
            break;
        default:
            break;
    }
}

void handle_ble_command(char c) {
    lastBleChar = c;

    switch (c) {
        case CMD_MODE_IDLE:
            set_mode(MODE_IDLE);
            break;
        case CMD_MODE_SENSOR_DBG:
            set_mode(MODE_SENSOR_DEBUG);
            break;
        case CMD_MODE_MOTOR_DBG:
            set_mode(MODE_MOTOR_DEBUG);
            break;
        case CMD_MODE_ENCODER_DBG:
            set_mode(MODE_ENCODER_DEBUG);
            break;
        case CMD_MODE_BLE_DBG:
            set_mode(MODE_BLE_DEBUG);
            break;
        case CMD_MODE_TD3_RUN:
            set_mode(MODE_TD3_RUN);
            break;

        case CMD_START:
            if (currentMode == MODE_TD3_RUN) {
                reset_motion_state();
                currentState = STATE_FOLLOW_LINE;
            } else if (currentState == STATE_STOPPED_WAIT_BLE) {
                currentState = STATE_FOLLOW_LINE;
            }
            break;

        case CMD_HALT:
            currentState = STATE_IDLE;
            stop_all_motors();
            break;

        case CMD_TURNAROUND:
            turnaroundRequested = true;
            break;

        case CMD_RESET_FAULTS:
            turnaroundRequested = false;
            reset_motion_state();
            currentState = STATE_IDLE;
            break;

        case CMD_PRINT_ONESHOT:
            print_status_once();
            break;

        case CMD_CPU_REPORT_TGL:
            ENABLE_CPU_REPORT = !ENABLE_CPU_REPORT;
            debug_printf("CPU_REPORT=%d\r\n", ENABLE_CPU_REPORT ? 1 : 0);
            break;

        case CMD_STREAM_TGL:
            ENABLE_STREAMING_DEBUG = !ENABLE_STREAMING_DEBUG;
            debug_printf("STREAM_DEBUG=%d\r\n", ENABLE_STREAMING_DEBUG ? 1 : 0);
            break;

        // 电机手动调试命令
        case CMD_MOTOR_STOP:
            if (currentMode == MODE_MOTOR_DEBUG) {
                targetSpeedLPct = 0.0f;
                targetSpeedRPct = 0.0f;
            }
            break;
        case CMD_MOTOR_FWD:
            if (currentMode == MODE_MOTOR_DEBUG) {
                targetSpeedLPct = motorDebugPct;
                targetSpeedRPct = motorDebugPct;
            }
            break;
        case CMD_MOTOR_REV:
            if (currentMode == MODE_MOTOR_DEBUG) {
                targetSpeedLPct = -motorDebugPct;
                targetSpeedRPct = -motorDebugPct;
            }
            break;
        case CMD_MOTOR_LEFT:
            if (currentMode == MODE_MOTOR_DEBUG) {
                targetSpeedLPct = -motorDebugPct;
                targetSpeedRPct =  motorDebugPct;
            }
            break;
        case CMD_MOTOR_RIGHT:
            if (currentMode == MODE_MOTOR_DEBUG) {
                targetSpeedLPct =  motorDebugPct;
                targetSpeedRPct = -motorDebugPct;
            }
            break;

        default:
            break;
    }
}

void poll_ble() {
    while (hm10.readable()) {
        char c = hm10.getc();
        handle_ble_command(c);
    }
}

//高层控制与状态机逻辑 

void update_follow_line_targets() {
    // 外环只负责生成左右轮目标速度，真正的 PWM 由内环 PI 完成。
    if (!lineVisible) {
        currentState = STATE_LOST_LINE;
        return;
    }

    const float dt = SENSOR_TASK_PERIOD_MS / 1000.0f;
    const float dErr = (lineError - lineErrorPrev) / dt;
    lineErrorPrev = lineError;

    float steer = LINE_STEER_KP * lineError + LINE_STEER_KD * dErr;
    steer = clampf(steer, -LINE_STEER_MAX, LINE_STEER_MAX);

    // 偏差越大时适当降速，使弯道更平滑。
    float speedReduction = clampf(fabsf(lineError) / 250.0f, 0.0f, 1.0f);
    float base = BASE_FOLLOW_SPEED_PCT - speedReduction * 8.0f;
    base = clampf(base, MIN_FOLLOW_SPEED_PCT, MAX_FOLLOW_SPEED_PCT);

    targetSpeedLPct = clampf(base - steer, -100.0f, 100.0f);
    targetSpeedRPct = clampf(base + steer, -100.0f, 100.0f);

    if (turnaroundRequested) {
        currentState = STATE_TURNAROUND_EXEC;
        turnaroundEntry = true;
        return;
    }

    // 终点判定要求：最近看见过线，然后持续消失一段时间。
    if (!lineVisible) {
        // 这里前面已经处理过，保留是为了增强可读性
        return;
    }
}

void enter_stopping_state() {
    currentState = STATE_STOPPING;
    float avgAbs = 0.5f * (fabsf(actualSpeedLPct) + fabsf(actualSpeedRPct));
    if (avgAbs < MIN_FOLLOW_SPEED_PCT) avgAbs = BASE_FOLLOW_SPEED_PCT;
    stoppingSpeedPct = avgAbs;
}

void update_stopping_targets() {
    const float dt = SENSOR_TASK_PERIOD_MS / 1000.0f;
    stoppingSpeedPct -= STOPPING_DECEL_PCT_PER_S * dt;
    if (stoppingSpeedPct < 0.0f) stoppingSpeedPct = 0.0f;

    targetSpeedLPct = stoppingSpeedPct;
    targetSpeedRPct = stoppingSpeedPct;

    if (stoppingSpeedPct <= 0.5f && fabsf(actualSpeedLPct) < 2.0f && fabsf(actualSpeedRPct) < 2.0f) {
        currentState = STATE_STOPPED_WAIT_BLE;
        stop_all_motors();
    }
}

void update_turnaround_targets() {
    if (turnaroundEntry) {
        reset_motion_state();
        turnaroundEntry = false;
    }

    targetSpeedLPct =  TURNAROUND_SPEED_PCT;
    targetSpeedRPct = -TURNAROUND_SPEED_PCT;

    const int avgTicks = (abs(leftEncoder.getPulses()) + abs(rightEncoder.getPulses())) / 2;
    if (avgTicks >= TURNAROUND_180_TICKS) {
        turnaroundRequested = false;
        reset_motion_state();
        currentState = STATE_FOLLOW_LINE;
    }
}

void update_lost_line_behavior() {
    // 先利用上一次误差方向做短时恢复。
    if (lineVisible) {
        currentState = STATE_FOLLOW_LINE;
        return;
    }

    if ((sysMs - lastLineSeenMs) <= LOST_LINE_RECOVER_MS) {
        const float steerDir = (lineError >= 0.0f) ? 1.0f : -1.0f;
        targetSpeedLPct = LOST_LINE_SEARCH_SPEED_PCT - steerDir * 8.0f;
        targetSpeedRPct = LOST_LINE_SEARCH_SPEED_PCT + steerDir * 8.0f;
        return;
    }

    // 若最近确实看见过线，且现在连续丢线足够久，则判定为终点。
    const uint32_t unseenMs = sysMs - lastLineSeenMs;
    if (unseenMs <= LINE_RECENTLY_VISIBLE_MS && unseenMs >= END_OF_LINE_CONFIRM_MS) {
        enter_stopping_state();
        return;
    }

    // 否则继续用更温和的搜索动作尝试找回线路。
    const float steerDir = (lineError >= 0.0f) ? 1.0f : -1.0f;
    targetSpeedLPct =  0.60f * LOST_LINE_SEARCH_SPEED_PCT - steerDir * 10.0f;
    targetSpeedRPct =  0.60f * LOST_LINE_SEARCH_SPEED_PCT + steerDir * 10.0f;
}

void update_vehicle_state_machine() {
    switch (currentState) {
        case STATE_BOOT:
            currentState = STATE_CALIBRATE;
            break;

        case STATE_CALIBRATE:
            // 启动标定阶段，电机保持关闭。
            targetSpeedLPct = 0.0f;
            targetSpeedRPct = 0.0f;
            // 初始采样稳定后回到 IDLE。
            if (sysMs > 300) {
                currentState = STATE_IDLE;
            }
            break;

        case STATE_IDLE:
            targetSpeedLPct = 0.0f;
            targetSpeedRPct = 0.0f;
            break;

        case STATE_FOLLOW_LINE:
            update_follow_line_targets();
            break;

        case STATE_TURNAROUND_EXEC:
            update_turnaround_targets();
            break;

        case STATE_STOPPING:
            update_stopping_targets();
            break;

        case STATE_STOPPED_WAIT_BLE:
            targetSpeedLPct = 0.0f;
            targetSpeedRPct = 0.0f;
            break;

        case STATE_LOST_LINE:
            update_lost_line_behavior();
            break;

        case STATE_FAULT:
        default:
            targetSpeedLPct = 0.0f;
            targetSpeedRPct = 0.0f;
            break;
    }
}

//调试任务 

void stream_sensor_debug() {
    debug_printf(
        "SENS amb=[%.3f %.3f %.3f %.3f %.3f %.3f] lit=[%.3f %.3f %.3f %.3f %.3f %.3f] sig=[%.3f %.3f %.3f %.3f %.3f %.3f] norm=[%.2f %.2f %.2f %.2f %.2f %.2f] vis=%d pos=%.1f err=%.1f pair=%.2f max=%d pairIdx=%d\r\n",
        lineAmbient[0], lineAmbient[1], lineAmbient[2], lineAmbient[3], lineAmbient[4], lineAmbient[5],
        lineLit[0], lineLit[1], lineLit[2], lineLit[3], lineLit[4], lineLit[5],
        lineSignal[0], lineSignal[1], lineSignal[2], lineSignal[3], lineSignal[4], lineSignal[5],
        lineNorm[0], lineNorm[1], lineNorm[2], lineNorm[3], lineNorm[4], lineNorm[5],
        lineVisible ? 1 : 0, linePosition, lineError, linePairMaxNorm, lineMaxIndex, linePairIndex
    );
}

void stream_encoder_debug() {
    debug_printf(
        "ENC pulsesL=%ld pulsesR=%ld actL=%.2f actR=%.2f tgtL=%.2f tgtR=%.2f cmdL=%.2f cmdR=%.2f\r\n",
        (long)leftEncoder.getPulses(), (long)rightEncoder.getPulses(),
        actualSpeedLPct, actualSpeedRPct, targetSpeedLPct, targetSpeedRPct, motorCmdLPct, motorCmdRPct
    );
}

void stream_ble_debug() {
    debug_printf("BLE last=%c mode=%s state=%s cpu=%d\r\n",
                 lastBleChar ? lastBleChar : '-', mode_name(currentMode), state_name(currentState), ENABLE_CPU_REPORT ? 1 : 0);
}

void stream_motor_debug() {
    debug_printf("MOTOR tgtL=%.1f tgtR=%.1f cmdL=%.1f cmdR=%.1f actL=%.1f actR=%.1f\r\n",
                 targetSpeedLPct, targetSpeedRPct, motorCmdLPct, motorCmdRPct, actualSpeedLPct, actualSpeedRPct);
}

void cpu_report_5s() {
    static uint32_t lastReportTimeUs = 0;
    const uint32_t now = now_us();
    const uint32_t elapsed = now - lastReportTimeUs;
    lastReportTimeUs = now;

    if (elapsed == 0) return;

    // busyUsAccum 统计的是 main() 中各任务耗时，ISR 设计得很轻，这里刻意不计入。
    float usage = 100.0f * ((float)busyUsAccum / (float)elapsed);
    if (usage < 0.0f) usage = 0.0f;
    if (usage > 100.0f) usage = 100.0f;

    if (ENABLE_CPU_REPORT) {
        debug_printf("CPU usage=%.1f%% mode=%s state=%s\r\n", usage, mode_name(currentMode), state_name(currentState));
    }

    busyUsAccum = 0;
}

//周期任务封装函数 

void do_control_task() {
    const uint32_t t0 = now_us();
    update_speed_estimates_and_PI();
    busyUsAccum += (now_us() - t0);
}

void do_5ms_task() {
    const uint32_t t0 = now_us();
    read_line_sensors_compensated();

    if (currentMode == MODE_TD3_RUN) {
        // 由于 lineVisible 每 5 ms 更新一次，因此在这里判断是否进入丢线状态。
        if (!lineVisible && currentState == STATE_FOLLOW_LINE) {
            currentState = STATE_LOST_LINE;
        }
    }

    busyUsAccum += (now_us() - t0);
}

void do_20ms_task() {
    static uint32_t debugDividerMs = 0;
    const uint32_t t0 = now_us();

    poll_ble();
    update_vehicle_state_machine();

    debugDividerMs += STATE_TASK_PERIOD_MS;
    if (ENABLE_STREAMING_DEBUG && debugDividerMs >= DEBUG_STREAM_PERIOD_MS) {
        debugDividerMs = 0;
        switch (currentMode) {
            case MODE_SENSOR_DEBUG:  stream_sensor_debug();  break;
            case MODE_MOTOR_DEBUG:   stream_motor_debug();   break;
            case MODE_ENCODER_DEBUG: stream_encoder_debug(); break;
            case MODE_BLE_DEBUG:     stream_ble_debug();     break;
            case MODE_TD3_RUN:
                // 正常运行模式下只输出较简洁的状态摘要
                print_status_once();
                break;
            default:
                break;
        }
    }

    busyUsAccum += (now_us() - t0);
}

void do_5s_task() {
    const uint32_t t0 = now_us();
    cpu_report_5s();
    busyUsAccum += (now_us() - t0);
}

//主函数 

int main() {
    pc.baud(115200);
    hm10.baud(9600);

    runTimer.start();
    lastCpuReportUs = now_us();

    set_motor_enable(true);
    set_all_line_leds(false);
    stop_all_motors();
    reset_motion_state();

    currentMode  = MODE_IDLE;
    currentState = STATE_BOOT;

    debug_printf("TD3 controller booting...\r\n");
    debug_printf("BLE cmds: 0/1/2/3/4/5 mode, G start, H halt, U turnaround, C cpu, D stream, P print\r\n");
    debug_printf("Motor dbg cmds: f b l r x\r\n");

    schedulerTicker.attach_us(&scheduler_isr, TICK_ISR_US);

    while (1) {
        uint32_t nCtrl = fetch_due(dueCtrl);
        uint32_t n5  = fetch_due(due5ms);
        uint32_t n20 = fetch_due(due20ms);
        uint32_t n5s = fetch_due(due5s);

        while (nCtrl--) {
            do_control_task();
        }
        while (n5--) {
            do_5ms_task();
        }
        while (n20--) {
            do_20ms_task();
        }
        while (n5s--) {
            do_5s_task();
        }

            // 适当空转等待，既避免无意义满速忙等，又保持较好响应速度。
        wait_us(50);
    }
}
