void PushRing(DebugSample ring[], int &head, int &count, const DebugSample &s) {
    ring[head] = s;
    head++;
    if (head >= LOG_BUFFER_SIZE) head = 0;

    if (count < LOG_BUFFER_SIZE) count++;
}

void CopyRingToLinear(const DebugSample ring[],
                      int head, int count,
                      DebugSample outBuf[],
                      int &outCount) {
    outCount = count;
    if (count <= 0) return;

    int start = head - count;
    while (start < 0) start += LOG_BUFFER_SIZE;

    for (int i = 0; i < count; ++i) {
        outBuf[i] = ring[(start + i) % LOG_BUFFER_SIZE];
    }
}

