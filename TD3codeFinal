struct LineInfo {
    bool lineVisible;
    float lineOffset;

    float minSig;
    float maxSig;
    float contrast;

    float rawSig[6];
    float normSig[6];

    float lineStrength;
    float pairMax;

    float leftSum;
    float rightSum;
    float lrBias;
};


LineInfo ReadLineInfo(SensorArray &sensorArrayRef, DigitalOut &statusLed) {
    LineInfo info;
    info.lineVisible = false;
    info.lineOffset = 0.0f;
    info.minSig = 999.0f;
    info.maxSig = -999.0f;
    info.contrast = 0.0f;
    info.lineStrength = 0.0f;
    info.pairMax = 0.0f;
    info.leftSum = 0.0f;
    info.rightSum = 0.0f;
    info.lrBias = 0.0f;

    for (int i = 0; i < 6; ++i) {
        info.rawSig[i] = 0.0f;
        info.normSig[i] = 0.0f;
    }

    sensorArrayRef.ReadCompensated(info.rawSig);

    for (int i = 0; i < 6; ++i) {
        if (info.rawSig[i] < info.minSig) info.minSig = info.rawSig[i];
        if (info.rawSig[i] > info.maxSig) info.maxSig = info.rawSig[i];
    }

    info.contrast = info.maxSig - info.minSig;

    float sumW = 0.0f;
    float sumNorm = 0.0f;

    for (int i = 0; i < 6; ++i) {
        float val = 0.0f;

        if (TRACK_IS_DARK_LINE) {
            val = info.maxSig - info.rawSig[i];
        } else {
            val = info.rawSig[i] - info.minSig;
        }

        if (val < info.contrast * 0.20f) {
            val = 0.0f;
        }

        info.normSig[i] = val;
        sumNorm += val;
        sumW += val * SENSOR_WEIGHTS[i];
    }

    info.lineStrength = sumNorm;

    for (int i = 0; i < 5; ++i) {
        float p = info.normSig[i] + info.normSig[i + 1];
        if (p > info.pairMax) info.pairMax = p;
    }

    info.leftSum  = info.normSig[0] + info.normSig[1] + info.normSig[2];
    info.rightSum = info.normSig[3] + info.normSig[4] + info.normSig[5];

    float lrDen = info.leftSum + info.rightSum;
    if (lrDen > 0.0001f) {
        info.lrBias = fabsf(info.leftSum - info.rightSum) / lrDen;
    } else {
        info.lrBias = 0.0f;
    }

    if (sumNorm > 0.0001f) {
        info.lineOffset = sumW / sumNorm;
    } else {
        info.lineOffset = 0.0f;
    }

    if (info.contrast >= LINE_CONTRAST_MIN &&
        info.maxSig >= LINE_RAW_MAX_MIN &&
        info.lineStrength >= LINE_STRENGTH_MIN &&
        info.pairMax >= LINE_PAIR_MIN) {
        info.lineVisible = true;
        statusLed = 0;
    } else {
        info.lineVisible = false;
        info.lineOffset = 0.0f;
        statusLed = 1;
    }

    return info;
}

struct WheelPIState {
    float targetL, targetR;
    float dutyL, dutyR;
    float integralL, integralR;
    float dutyMin, dutyMax;
    float integralLimit;
    float maxDutyStep;
    float ffGain;
};

float CountsToWheelSpeedMps(int deltaCounts, float dt_s) {
    return (((float)deltaCounts) / (COUNTS_PER_MOTOR_REV * GEAR_RATIO) / dt_s)
         * (2.0f * PI_F * WHEEL_RADIUS_M);
}

void UpdateWheelPI(float speedL, float speedR, float dt_s,
                   float Kp, float Ki,
                   WheelPIState &state,
                   MotorDriveBoard &motorRef) {
    float errorL = state.targetL - speedL;
    float errorR = state.targetR - speedR;

    state.integralL = clampf(state.integralL + errorL * dt_s,
                             -state.integralLimit, state.integralLimit);
    state.integralR = clampf(state.integralR + errorR * dt_s,
                             -state.integralLimit, state.integralLimit);

    float cmdL = clampf(state.ffGain * state.targetL + Kp * errorL + Ki * state.integralL,
                        state.dutyMin, state.dutyMax);
    float cmdR = clampf(state.ffGain * state.targetR + Kp * errorR + Ki * state.integralR,
                        state.dutyMin, state.dutyMax);

    state.dutyL = clampf(state.dutyL + clampf(cmdL - state.dutyL,
                                              -state.maxDutyStep, state.maxDutyStep),
                         state.dutyMin, state.dutyMax);

    state.dutyR = clampf(state.dutyR + clampf(cmdR - state.dutyR,
                                              -state.maxDutyStep, state.maxDutyStep),
                         state.dutyMin, state.dutyMax);

    motorRef.SetDutyCycle(state.dutyL, state.dutyR);
}

