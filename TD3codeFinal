static void ResetPIStateToZero() {
    g_piState.targetL = 0.0f;
    g_piState.targetR = 0.0f;
    g_piState.dutyL = 0.0f;
    g_piState.dutyR = 0.0f;
    g_piState.integralL = 0.0f;
    g_piState.integralR = 0.0f;
}

static void ResetDynamicTrackingState(float error) {
    g_lastLineError = error;
    g_lastDerivative = 0.0f;
    g_curveScoreFilt = 0.0f;
    g_steerSatTimer = 0.0f;
    g_baseSpeedFilt = SPEED_CRUISE;
    g_boostConfirmTimer = 0.0f;
    g_straightBoostActive = false;
}

static void ForceMotorStop() {
    motor.SetDirection(0, 0);
    motor.SetDutyCycle(0.0f, 0.0f);
}


int main() {
    pc.baud(115200);
    hm10.baud(9600);

    motor.SetMode(0, 0);
    motor.SetDirection(0, 0);
    motor.SetPeriod(0.001f, 0.001f);
    motor.SetEnable(1);
    motor.SetDutyCycle(0.0f, 0.0f);

    sensorArray.SetAllLEDs(0);
    wait_us(300000);

    g_piState.dutyMin = DUTY_MIN;
    g_piState.dutyMax = DUTY_MAX;
    g_piState.integralLimit = WHEEL_INT_LIMIT;
    g_piState.maxDutyStep = DUTY_STEP_LIMIT;
    g_piState.ffGain = WHEEL_FF_GAIN;
    ResetPIStateToZero();

    g_lastPulseL = encoderL.getPulses();
    g_lastPulseR = encoderR.getPulses();
    g_turnStartPulseL = g_lastPulseL;
    g_turnStartPulseR = g_lastPulseR;

    controlTicker.attach(&controlISR, CONTROL_PERIOD_S);

    while (1) {
        while (hm10.readable()) {
            char bleChar = hm10.getc();
            if ((bleChar == 'A' || bleChar == 'a') && g_runArmed) {
                g_turnCommandPending = true;
            }
        }

        if (!controlFlag) {
            wait_us(10);
            continue;
        }
        controlFlag = false;

        LineInfo line = ReadLineInfo(sensorArray, led);
        float error = -line.lineOffset;

        int pulseL = encoderL.getPulses();
        int pulseR = encoderR.getPulses();

        int deltaL = pulseL - g_lastPulseL;
        int deltaR = pulseR - g_lastPulseR;

        g_lastPulseL = pulseL;
        g_lastPulseR = pulseR;

        float speedL = -CountsToWheelSpeedMps(deltaL, CONTROL_PERIOD_S);
        float speedR = -CountsToWheelSpeedMps(deltaR, CONTROL_PERIOD_S);

        bool reacquiredThisCycle = false;

        g_dbgKpEff = 0.0f;
        g_dbgKdEff = 0.0f;
        g_dbgPredError = error;
        g_dbgSteerSpeed = 0.0f;
        g_dbgBaseSpeed = SPEED_TIGHT;
        g_dbgMaxSteerEff = MAX_STEER_STRAIGHT;
        g_dbgCurveScore = g_curveScoreFilt;
        g_dbgBoost = g_straightBoostActive ? 1 : 0;

        if (!g_runArmed) {
            if (line.lineVisible) {
                g_armedVisibleTimer += CONTROL_PERIOD_S;
                if (g_armedVisibleTimer >= RUN_ARM_VISIBLE_S) {
                    g_runArmed = true;
                    g_carState = STATE_TRACKING;
                    g_visibleStableTimer = 0.0f;
                    g_recoveryTimer = 0.0f;
                    g_lostTimer = 0.0f;
                    ResetDynamicTrackingState(error);
                    g_stopDumpDone = false;
                    frozenValid = false;
                    frozenLongValid = false;
                }
            } else {
                g_armedVisibleTimer = 0.0f;
            }

            ResetPIStateToZero();
            ForceMotorStop();
            continue;
        }

        if (g_turnCommandPending && g_carState != STATE_TURNAROUND_180) {
            g_turnCommandPending = false;

            g_carState = STATE_TURNAROUND_180;
            g_turnStartPulseL = pulseL;
            g_turnStartPulseR = pulseR;

            g_lostTimer = 0.0f;
            g_recoveryTimer = 0.0f;

            g_lastLineError = 0.0f;
            g_lastDerivative = 0.0f;
            g_curveScoreFilt = 0.0f;
            g_steerSatTimer = 0.0f;
            g_baseSpeedFilt = SPEED_TIGHT;
            g_boostConfirmTimer = 0.0f;
            g_straightBoostActive = false;

            ResetPIStateToZero();
            motor.SetDutyCycle(0.0f, 0.0f);
            g_stopDumpDone = false;
        }


        if (g_carState != STATE_TURNAROUND_180) {
            if (line.lineVisible) {
                g_visibleStableTimer += CONTROL_PERIOD_S;

                if (g_carState == STATE_STOPPED_RECOVERY) {
                    g_recoveryTimer += CONTROL_PERIOD_S;

                    if (g_recoveryTimer >= RECOVERY_GO_DELAY_S) {
                        g_carState = STATE_TRACKING;
                        ResetDynamicTrackingState(error);
                        g_piState.integralL = 0.0f;
                        g_piState.integralR = 0.0f;
                        g_stopDumpDone = false;
                    }
                } else {
                    if (g_carState == STATE_LOST_SEARCH) {
                        reacquiredThisCycle = true;
                    }

                    g_carState = STATE_TRACKING;
                    g_lostTimer = 0.0f;
                    g_recoveryTimer = 0.0f;
                    g_stopDumpDone = false;
                }

                if (g_visibleStableTimer >= FROZEN_CLEAR_VISIBLE_S) {
                    frozenValid = false;
                    frozenLongValid = false;
                }
            } else {
                g_visibleStableTimer = 0.0f;

                if (g_carState == STATE_TRACKING) {
                    CopyRingToLinear(liveRing, liveHead, liveCount, frozenBuf, frozenCount);
                    frozenValid = (frozenCount > 0);

                    CopyCompactRingToLinear(longRing, longHead, longCount,
                                            frozenLongBuf, frozenLongCount);
                    frozenLongValid = (frozenLongCount > 0);

                    g_carState = STATE_LOST_SEARCH;
                    g_lostTimer = CONTROL_PERIOD_S;
                    g_recoveryTimer = 0.0f;
                }
                else if (g_carState == STATE_LOST_SEARCH) {
                    g_lostTimer += CONTROL_PERIOD_S;

                    if (g_lostTimer >= LOST_STOP_TIME_S) {
                        g_carState = STATE_STOPPED_RECOVERY;
                        g_recoveryTimer = 0.0f;
                    }
                }
                else if (g_carState == STATE_STOPPED_RECOVERY) {
                    g_recoveryTimer = 0.0f;
                }
            }
        }

        if (g_carState == STATE_TURNAROUND_180) {
            int turnedL = iabs_i(pulseL - g_turnStartPulseL);
            int turnedR = iabs_i(pulseR - g_turnStartPulseR);
            int turnAvg = (turnedL + turnedR) / 2;
            int remain  = TURN_180_TICKS - turnAvg;

            if (remain <= 0) {
                motor.SetDutyCycle(0.0f, 0.0f);
                motor.SetDirection(0, 0);

                if (line.lineVisible) {
                    g_carState = STATE_TRACKING;
                    ResetDynamicTrackingState(error);
                    g_piState.integralL = 0.0f;
                    g_piState.integralR = 0.0f;
                    frozenValid = false;
                    frozenLongValid = false;
                } else {
                    CopyRingToLinear(liveRing, liveHead, liveCount, frozenBuf, frozenCount);
                    frozenValid = (frozenCount > 0);

                    CopyCompactRingToLinear(longRing, longHead, longCount,
                                            frozenLongBuf, frozenLongCount);
                    frozenLongValid = (frozenLongCount > 0);

                    g_carState = STATE_LOST_SEARCH;
                    g_lostTimer = 0.0f;
                    g_recoveryTimer = 0.0f;
                    g_lastDerivative = 0.0f;
                    g_curveScoreFilt = 0.0f;
                    g_steerSatTimer = 0.0f;
                    g_baseSpeedFilt = SPEED_TIGHT;
                    g_boostConfirmTimer = 0.0f;
                    g_straightBoostActive = false;
                }
            } else {
                float baseDuty = TURN_BASE_DUTY;

                if (remain < TURN_SLOW_ZONE_TICKS) {
                    float k = (float)remain / (float)TURN_SLOW_ZONE_TICKS;
                    k = clampf(k, 0.0f, 1.0f);
                    baseDuty = TURN_MIN_DUTY + k * (TURN_BASE_DUTY - TURN_MIN_DUTY);
                }

                float syncErr = (float)(turnedL - turnedR);
                float corr = clampf(TURN_SYNC_KP * syncErr, -0.05f, 0.05f);

                float dutyL = clampf(baseDuty - corr, 0.0f, DUTY_MAX);
                float dutyR = clampf(baseDuty + corr, 0.0f, DUTY_MAX);

                if (TURN_LEFT_FORWARD) {
                    motor.SetDirection(0, 1);
                } else {
                    motor.SetDirection(1, 0);
                }

                motor.SetDutyCycle(dutyL, dutyR);

                g_piState.targetL = 0.0f;
                g_piState.targetR = 0.0f;
                g_piState.dutyL = dutyL;
                g_piState.dutyR = dutyR;
            }
        }
        else if (g_carState == STATE_STOPPED_RECOVERY) {
            ResetPIStateToZero();
            ForceMotorStop();
        }
        else if (g_carState == STATE_LOST_SEARCH) {
            g_lastDerivative = 0.0f;
            g_curveScoreFilt = 1.0f;
            g_steerSatTimer = 0.0f;
            g_boostConfirmTimer = 0.0f;
            g_straightBoostActive = false;
            g_baseSpeedFilt = SPEED_TIGHT;

            ResetPIStateToZero();
            ForceMotorStop();
        }
        else {

            if (reacquiredThisCycle) {
                ResetDynamicTrackingState(error);
            }

            if (fabsf(error) <= CENTER_DEADBAND) {
                g_lastDerivative = 0.0f;
                g_lastLineError = error;
            } else {
                float rawDerivative = (error - g_lastLineError) / CONTROL_PERIOD_S;
                float filteredDerivative =
                    D_FILTER_ALPHA * rawDerivative +
                    (1.0f - D_FILTER_ALPHA) * g_lastDerivative;

                filteredDerivative = clampf(filteredDerivative,
                                            -DERIVATIVE_LIMIT,
                                             DERIVATIVE_LIMIT);

                g_lastDerivative = filteredDerivative;
                g_lastLineError = error;
            }

            float eNorm = clampf(fabsf(error) / 120.0f, 0.0f, 1.0f);
            float dNorm = clampf(fabsf(g_lastDerivative) / 600.0f, 0.0f, 1.0f);
            float cNorm = clampf(line.lrBias, 0.0f, 1.0f);

            float curveScoreRaw =
                0.50f * eNorm +
                0.15f * dNorm +
                0.35f * cNorm;

            curveScoreRaw = clampf(curveScoreRaw, 0.0f, 1.0f);

            g_curveScoreFilt =
                CURVE_SCORE_FILTER_NEW * curveScoreRaw +
                CURVE_SCORE_FILTER_OLD * g_curveScoreFilt;

            g_curveScoreFilt = clampf(g_curveScoreFilt, 0.0f, 1.0f);
            g_dbgCurveScore = g_curveScoreFilt;

            bool straightCandidate =
                line.lineVisible &&
                (fabsf(error) < BOOST_ERR_ABS_MAX) &&
                (fabsf(g_lastDerivative) < BOOST_DER_ABS_MAX) &&
                (line.lrBias < BOOST_LRBIAS_MAX) &&
                (g_curveScoreFilt < BOOST_CURVE_MAX);

            if (straightCandidate) {
                g_boostConfirmTimer += CONTROL_PERIOD_S;
                if (g_boostConfirmTimer >= BOOST_ENTER_TIME_S) {
                    g_straightBoostActive = true;
                }
            } else {
                g_boostConfirmTimer = 0.0f;
                g_straightBoostActive = false;
            }

            float desiredBase = SPEED_CRUISE -
                (SPEED_CRUISE - SPEED_TIGHT) * sqrtf(g_curveScoreFilt);

            if (desiredBase < SPEED_TIGHT) desiredBase = SPEED_TIGHT;
            if (desiredBase > SPEED_CRUISE) desiredBase = SPEED_CRUISE;

            if (g_straightBoostActive) {
                desiredBase = SPEED_STRAIGHT;
            }

            float roughMaxSteer =
                MAX_STEER_STRAIGHT +
                g_curveScoreFilt * (MAX_STEER_CORNER - MAX_STEER_STRAIGHT);

            float roughKp =
                LINE_KP_STRAIGHT +
                g_curveScoreFilt * (LINE_KP_CORNER - LINE_KP_STRAIGHT);

            float roughKd =
                LINE_KD_STRAIGHT +
                g_curveScoreFilt * (LINE_KD_CORNER - LINE_KD_STRAIGHT);

            float roughPred = error + PREVIEW_T * g_lastDerivative;
            roughPred = clampf(roughPred, -500.0f, 500.0f);

            float roughSteer = 0.0f;
            if (fabsf(error) > CENTER_DEADBAND) {
                roughSteer = roughKp * roughPred + roughKd * g_lastDerivative;
                roughSteer = clampf(roughSteer, -roughMaxSteer, roughMaxSteer);
            }

            if (fabsf(roughSteer) > (STEER_SAT_RATIO * roughMaxSteer)) {
                g_steerSatTimer += CONTROL_PERIOD_S;
            } else {
                g_steerSatTimer = 0.0f;
            }

            if (g_steerSatTimer >= STEER_SAT_REDUCE_S) {
                if (desiredBase > STEER_SAT_REDUCED_SPEED) {
                    desiredBase = STEER_SAT_REDUCED_SPEED;
                }
                g_straightBoostActive = false;
                g_boostConfirmTimer = 0.0f;
            }

            g_baseSpeedFilt =
                BASE_SPEED_FILTER_NEW * desiredBase +
                BASE_SPEED_FILTER_OLD * g_baseSpeedFilt;

            g_baseSpeedFilt = clampf(g_baseSpeedFilt, SPEED_TIGHT, SPEED_STRAIGHT);

            float KpEff =
                LINE_KP_STRAIGHT +
                g_curveScoreFilt * (LINE_KP_CORNER - LINE_KP_STRAIGHT);

            float KdEff =
                LINE_KD_STRAIGHT +
                g_curveScoreFilt * (LINE_KD_CORNER - LINE_KD_STRAIGHT);

            float maxSteerEff =
                MAX_STEER_STRAIGHT +
                g_curveScoreFilt * (MAX_STEER_CORNER - MAX_STEER_STRAIGHT);

            g_dbgKpEff = KpEff;
            g_dbgKdEff = KdEff;
            g_dbgMaxSteerEff = maxSteerEff;

            float predError = error + PREVIEW_T * g_lastDerivative;
            predError = clampf(predError, -500.0f, 500.0f);
            g_dbgPredError = predError;

            float steerSpeed = 0.0f;
            if (fabsf(error) <= CENTER_DEADBAND) {
                steerSpeed = 0.0f;
            } else {
                steerSpeed = KpEff * predError + KdEff * g_lastDerivative;
                steerSpeed = clampf(steerSpeed, -maxSteerEff, maxSteerEff);
            }

            g_dbgBaseSpeed = g_baseSpeedFilt;
            g_dbgSteerSpeed = steerSpeed;
            g_dbgBoost = g_straightBoostActive ? 1 : 0;

            g_piState.targetL = g_baseSpeedFilt - steerSpeed;
            g_piState.targetR = g_baseSpeedFilt + steerSpeed;

            g_piState.targetL = clampf(g_piState.targetL,
                                       TARGET_SPEED_MIN_TRACK,
                                       TARGET_SPEED_MAX_TRACK);
            g_piState.targetR = clampf(g_piState.targetR,
                                       TARGET_SPEED_MIN_TRACK,
                                       TARGET_SPEED_MAX_TRACK);

            motor.SetDirection(0, 0);
            UpdateWheelPI(speedL, speedR, CONTROL_PERIOD_S,
                          WHEEL_KP, WHEEL_KI,
                          g_piState, motor);
        }


        logSampleDivider++;
        if (logSampleDivider >= LOG_SAMPLE_DIVIDER) {
            logSampleDivider = 0;

            static DebugSample s;
            s.seq   = logSeq++;
            s.state = (int)g_carState;
            s.vis   = line.lineVisible ? 1 : 0;
            s.boost = g_dbgBoost;

            s.off   = line.lineOffset;
            s.err   = error;
            s.pred  = g_dbgPredError;
            s.der   = g_lastDerivative;
            s.curve = g_dbgCurveScore;

            s.kp    = g_dbgKpEff;
            s.kd    = g_dbgKdEff;
            s.integ = 0.0f;
            s.steer = g_dbgSteerSpeed;
            s.base  = g_dbgBaseSpeed;
            s.maxSteer = g_dbgMaxSteerEff;

            s.tL    = g_piState.targetL;
            s.tR    = g_piState.targetR;
            s.sL    = speedL;
            s.sR    = speedR;
            s.dL    = g_piState.dutyL;
            s.dR    = g_piState.dutyR;

            s.contrast = line.contrast;
            s.strength = line.lineStrength;
            s.lrBias   = line.lrBias;

            for (int i = 0; i < 6; ++i) {
                s.raw[i] = line.rawSig[i];
            }

            PushRing(liveRing, liveHead, liveCount, s);
        }

        longLogSampleDivider++;
        if (longLogSampleDivider >= LONG_LOG_SAMPLE_DIVIDER) {
            longLogSampleDivider = 0;

            static CompactDebugSample s2;
            s2.seq   = logSeq;
            s2.state = (unsigned char)g_carState;
            s2.vis   = line.lineVisible ? 1 : 0;
            s2.boost = (unsigned char)g_dbgBoost;

            s2.off_x10      = (short)clampf(line.lineOffset * 10.0f,   -32768.0f, 32767.0f);
            s2.err_x10      = (short)clampf(error * 10.0f,             -32768.0f, 32767.0f);
            s2.der_x1       = (short)clampf(g_lastDerivative,          -32768.0f, 32767.0f);
            s2.curve_x1000  = (short)clampf(g_dbgCurveScore * 1000.0f,    0.0f, 32767.0f);

            s2.base_x1000   = (short)clampf(g_dbgBaseSpeed * 1000.0f,  -32768.0f, 32767.0f);
            s2.steer_x1000  = (short)clampf(g_dbgSteerSpeed * 1000.0f, -32768.0f, 32767.0f);

            s2.tL_x1000     = (short)clampf(g_piState.targetL * 1000.0f, -32768.0f, 32767.0f);
            s2.tR_x1000     = (short)clampf(g_piState.targetR * 1000.0f, -32768.0f, 32767.0f);
            s2.sL_x1000     = (short)clampf(speedL * 1000.0f,            -32768.0f, 32767.0f);
            s2.sR_x1000     = (short)clampf(speedR * 1000.0f,            -32768.0f, 32767.0f);
            s2.dL_x1000     = (short)clampf(g_piState.dutyL * 1000.0f,       0.0f, 32767.0f);
            s2.dR_x1000     = (short)clampf(g_piState.dutyR * 1000.0f,       0.0f, 32767.0f);

            s2.contrast_x1000 = (unsigned short)clampf(line.contrast * 1000.0f,     0.0f, 65535.0f);
            s2.strength_x1000 = (unsigned short)clampf(line.lineStrength * 1000.0f, 0.0f, 65535.0f);
            s2.lrBias_x1000   = (unsigned short)clampf(line.lrBias * 1000.0f,       0.0f, 65535.0f);

            PushCompactRing(longRing, longHead, longCount, s2);
        }


        if (g_carState == STATE_LOST_SEARCH &&
            !g_stopDumpDone &&
            g_lostTimer >= PRESTOP_DUMP_DELAY_S) {

            g_stopDumpDone = true;

            if (frozenLongValid && frozenLongCount > 0) {
                DumpCompactBuffer(pc, frozenLongBuf, frozenLongCount, LONG_DUMP_COUNT);
            }

            if (frozenValid && frozenCount > 0) {
                DumpLinearBuffer(pc, frozenBuf, frozenCount, STOP_DUMP_COUNT);
            }
        }

        // ====================================================
        // STOPPED 兜底再打印一次
        // ====================================================
        if (g_carState == STATE_STOPPED_RECOVERY &&
            !g_stopDumpDone) {

            g_stopDumpDone = true;

            if (frozenLongValid && frozenLongCount > 0) {
                DumpCompactBuffer(pc, frozenLongBuf, frozenLongCount, LONG_DUMP_COUNT);
            }

            if (frozenValid && frozenCount > 0) {
                DumpLinearBuffer(pc, frozenBuf, frozenCount, STOP_DUMP_COUNT);
            } else {
                CopyRingToLinear(liveRing, liveHead, liveCount, fallbackBuf, fallbackCount);
                DumpLinearBuffer(pc, fallbackBuf, fallbackCount, STOP_DUMP_COUNT);
            }
        }
    }
}
