class SensorArray {
private:
    DigitalOut uln1, uln2, uln3, uln4, uln5, uln6;
    AnalogIn tr1, tr2, tr3, tr4, tr5, tr6;

    void SetLEDsRaw(int u1, int u2, int u3, int u4, int u5, int u6) {
        uln1.write(u1); uln2.write(u2); uln3.write(u3);
        uln4.write(u4); uln5.write(u5); uln6.write(u6);
    }

    float ReadAvg(AnalogIn &ch) {
        float sum = 0.0f;
        for (int i = 0; i < ADC_AVG_SAMPLES; ++i) {
            sum += ch.read();
        }
        return sum / (float)ADC_AVG_SAMPLES;
    }

    void ReadRaw(float out[6]) {
        out[0] = ReadAvg(tr1);
        out[1] = ReadAvg(tr2);
        out[2] = ReadAvg(tr3);
        out[3] = ReadAvg(tr4);
        out[4] = ReadAvg(tr5);
        out[5] = ReadAvg(tr6);
    }

public:
    SensorArray(PinName u1, PinName u2, PinName u3,
                PinName u4, PinName u5, PinName u6,
                PinName t1, PinName t2, PinName t3,
                PinName t4, PinName t5, PinName t6)
        : uln1(u1), uln2(u2), uln3(u3),
          uln4(u4), uln5(u5), uln6(u6),
          tr1(t1), tr2(t2), tr3(t3),
          tr4(t4), tr5(t5), tr6(t6) {}

    void SetAllLEDs(int on) {
        SetLEDsRaw(on, on, on, on, on, on);
    }

    void ReadCompensated(float signal[6]) {
        float ambient[6] = {0};
        float lit[6] = {0};

        SetAllLEDs(0);
        wait_us(LED_SETTLE_US);
        ReadRaw(ambient);

        SetAllLEDs(1);
        wait_us(LED_SETTLE_US);
        ReadRaw(lit);

        for (int i = 0; i < 6; ++i) {
            signal[i] = lit[i] - ambient[i];
            if (signal[i] < 0.0f) signal[i] = 0.0f;
        }
    }
};

